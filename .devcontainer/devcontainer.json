{
  "name": "opencode devcontainer workspace",
  "initializeCommand": "mkdir -p .ai_memory .ai_working/opencode_data .ai_working/opencode_data/state",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "mounts": [
    "source=${localWorkspaceFolder}/.ai_working/opencode_data,target=/home/vscode/.local/share/opencode,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/.ai_working/opencode_data/state,target=/home/vscode/.local/state,type=bind,consistency=cached",
    "source=/etc/localtime,target=/etc/localtime,type=bind,readonly=true",
    "source=/etc/timezone,target=/etc/timezone,type=bind,readonly=true"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylint",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-json"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "editor.formatOnSave": true
      }
    }
  },
  "forwardPorts": [
    3000,
    11434
  ],
  "portsAttributes": {
    "3000": {
      "label": "Preview",
      "onAutoForward": "notify"
    },
    "11434": {
      "label": "Ollama",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "bash .devcontainer/setup_devcontainer.sh",
  "containerEnv": {
    "OLLAMA_MODELS": "qwen2.5-coder:7b codellama:13b llama3.2:3b"
  },
  "remoteUser": "vscode"
}